<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>$(LibraryMajorVersion).$(DevWinUI_Shader_MinorVersion).$(DevWinUI_Shader_PatchVersion)$(PreviewBuildSuffix)</Version>
    <PackageId>$(BaseNamespace).Shader</PackageId>
    <AssemblyName>$(BaseNamespace).Shader</AssemblyName>
    <Description>
      A high-performance WinUI shader library powered by ComputeSharp and Win2D, enabling GPU-accelerated animated procedural backgrounds using custom HLSL compute shaders with smooth real-time rendering.
    </Description>
    <PackageTags>winui winui3 win11 xaml shader shaders computesharp DevWinUI DevWinUI.Controls projectreunion winappsdk windowsappsdk wasdk reunion win2d composition</PackageTags>
  </PropertyGroup>
  
  <ItemGroup>
    <PackageReference Include="Microsoft.Graphics.Win2D" Version="$(Win2dVersion)" />
    <PackageReference Include="ComputeSharp.D2D1.WinUI" Version="$(ComputeSharpVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DevWinUI.Base\DevWinUI.Base.csproj" />
  </ItemGroup>
</Project>