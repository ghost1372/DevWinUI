<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="DevWinUIGallery.Views.SpeedGraphPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:DevWinUIGallery"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="10">
            <local:ControlExample DocPage="controls/speedGraph" HeaderText="Speed Graph">
                <local:ControlExample.Xaml>
                    <x:String>
                        &lt;dev:SpeedGraph /&gt;
                    </x:String>
                </local:ControlExample.Xaml>
                <local:ControlExample.CSharp>
                    <x:String>
                        SpeedGraph.SetSpeed(percent, speed);
                    </x:String>
                </local:ControlExample.CSharp>
                <local:ControlExample.Pane>
                    <StackPanel Spacing="10">
                        <Button x:Name="BtnCopy" Click="BtnCopy_Click" Content="Starting file copy simulation" />
                        <Button x:Name="BtnError" Click="BtnError_Click" Content="Error" />
                        <Button x:Name="BtnWarning" Click="BtnPause_Click" Content="Pause" />
                        <Button x:Name="BtnNormal" Click="BtnNormal_Click" Content="Normal" />
                        <ToggleSwitch x:Name="TGShowLine" Header="Show Speed Line" IsOn="True" />
                        <ToggleSwitch x:Name="TGShowText" Header="Show Speed Text" IsOn="True" />
                        <ToggleSwitch x:Name="TGAutoUpdate" Header="Auto Update Speed Text" IsOn="True" />
                        <ComboBox x:Name="CmbBackgroundMode" Header="Background Mode" ItemsSource="{x:Bind SpeedGraphBackgroundModeItems, Mode=OneWay}" SelectedIndex="0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="dev:SpeedGraphBackgroundMode">
                                    <TextBlock Text="{x:Bind}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <NumberBox x:Name="NBFileSize" Header="File Size (MB)" Maximum="5000" Minimum="100" Value="500" />

                    </StackPanel>
                </local:ControlExample.Pane>
                <dev:SpeedGraph x:Name="SpeedGraphSample" AutoUpdateSpeedText="{x:Bind TGAutoUpdate.IsOn, Mode=OneWay}" BackgroundMode="{x:Bind ((dev:SpeedGraphBackgroundMode)CmbBackgroundMode.SelectedItem), Mode=OneWay}" SpeedLineVisibility="{x:Bind TGShowLine.IsOn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" SpeedTextVisibility="{x:Bind TGShowText.IsOn, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </local:ControlExample>
            <local:ControlExample DocPage="controls/speedGraph2" HeaderText="Speed Graph 2">
                <local:ControlExample.Xaml>
                    <x:String>
                        &lt;dev:SpeedGraph2 x:Name="SpeedGraphSample2" /&gt;
                    </x:String>
                </local:ControlExample.Xaml>
                <local:ControlExample.CSharp>
                    <x:String>
                        SpeedGraphSample2.Points.Add(new Vector2(percent, speed));
                    </x:String>
                </local:ControlExample.CSharp>
                <local:ControlExample.Pane>
                    <StackPanel Spacing="10">
                        <Button x:Name="BtnCopy2" Click="BtnCopy_Click2" Content="Starting file copy simulation" />
                        <Button x:Name="BtnError2" Click="BtnError_Click2" Content="Error" />
                        <Button x:Name="BtnWarning2" Click="BtnPause_Click2" Content="Warning" />
                        <Button x:Name="BtnSuccess2" Click="BtnSuccess_Click2" Content="Success" />
                        <Button x:Name="BtnNormal2" Click="BtnNormal_Click" Content="Normal" />
                        <NumberBox x:Name="NBFileSize2" Header="File Size (MB)" Maximum="5000" Minimum="100" Value="500" />

                    </StackPanel>
                </local:ControlExample.Pane>
                <dev:SpeedGraph2 x:Name="SpeedGraphSample2" HorizontalAlignment="Stretch" />
            </local:ControlExample>

        </StackPanel>
    </ScrollViewer>

</Page>
