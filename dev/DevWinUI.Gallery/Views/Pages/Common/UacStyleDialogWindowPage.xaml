<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="DevWinUIGallery.Views.UacStyleDialogWindowPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:DevWinUIGallery"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="10">
            <local:ControlExample DocPage="controls/uacStyleDialogWindow"
                                  HeaderText="UacStyleDialogWindow">
                <local:ControlExample.CSharp>
                    <x:String>
                        UacStyleDialogWindow dialog = new()#nl#
                        {#nl#
                        Header = txtTitle.Text,#nl#
                        Content = txtContent.Text,#nl#
                        };#nl#
                        dialog.ShowDialog();
                    </x:String>
                </local:ControlExample.CSharp>
                <local:ControlExample.Pane>
                    <StackPanel Spacing="10">
                        <TextBox x:Name="txtTitle"
                                 Header="Header"
                                 PlaceholderText="Header"
                                 Text="Header" />
                        <TextBox x:Name="txtContent"
                                 Header="Content"
                                 PlaceholderText="Content"
                                 Text="Content" />
                        <ToggleSwitch x:Name="TGHasTitleBar"
                                      Header="Has TitleBar"
                                      IsOn="True" />
                        <ToggleSwitch x:Name="TGIsResizable"
                                      Header="Can Resize?"
                                      IsOn="False" />
                        <ComboBox x:Name="CmbUnderlayBackdrops"
                                  Header="Backdrop"
                                  ItemsSource="{x:Bind BackdropItems, Mode=OneWay}"
                                  SelectedIndex="1" />
                        <ComboBox x:Name="CmbFlow"
                                  Header="FlowDirection"
                                  ItemsSource="{x:Bind FlowDirectionItems, Mode=OneWay}"
                                  SelectedIndex="0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="FlowDirection">
                                    <TextBlock Style="{ThemeResource BaseTextBlockStyle}"
                                               Text="{x:Bind}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="CmbSeverity"
                                  Header="Severity"
                                  ItemsSource="{x:Bind SeverityItems, Mode=OneWay}"
                                  SelectedIndex="1">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="InfoBarSeverity">
                                    <TextBlock Style="{ThemeResource BaseTextBlockStyle}"
                                               Text="{x:Bind}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </local:ControlExample.Pane>
                <StackPanel Spacing="10">
                    <Button Click="Button_Click"
                            Content="Show Dialog" />
                </StackPanel>
            </local:ControlExample>
        </StackPanel>
    </ScrollViewer>

</Page>
