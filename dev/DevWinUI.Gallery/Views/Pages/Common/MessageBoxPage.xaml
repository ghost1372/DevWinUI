<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="DevWinUIGallery.Views.MessageBoxPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:DevWinUIGallery"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="10" dev:PanelAttach.ChildrenTransitions="Default" Spacing="10">
            <local:ControlExample DocPage="controls/messageBox"
                                  HeaderText="MessageBox">
                <local:ControlExample.CSharp>
                    <x:String>
                        await MessageBox.ShowAsync("Content", "Title");
                    </x:String>
                </local:ControlExample.CSharp>
                <local:ControlExample.Pane>
                    <StackPanel Spacing="10">
                        <TextBox x:Name="txtTitle"
                                 Header="Title"
                                 PlaceholderText="Title"
                                 Text="Title" />
                        <TextBox x:Name="txtContent"
                                 Header="Content"
                                 PlaceholderText="Content"
                                 Text="Content" />
                        <ComboBox x:Name="CmbFlow"
                                  Header="FlowDirection"
                                  ItemsSource="{x:Bind FlowDirectionItems, Mode=OneWay}"
                                  SelectedIndex="0" />
                        <ComboBox x:Name="CmbWindowStartupLocation"
                                  Header="WindowStartupLocation"
                                  ItemsSource="{x:Bind WindowStartupLocationItems, Mode=OneWay}"
                                  SelectedIndex="2" />
                        <ComboBox x:Name="CmbMessageBoxButtons"
                                  Header="MessageBox Buttons"
                                  ItemsSource="{x:Bind MessageBoxButtonItems, Mode=OneWay}"
                                  SelectedIndex="0" />
                        <ComboBox x:Name="CmbMessageBoxDefaultButton"
                                  Header="MessageBox Default Button"
                                  ItemsSource="{x:Bind MessageBoxDefaultButtonItems, Mode=OneWay}"
                                  SelectedIndex="0" />
                        <ComboBox x:Name="CmbMessageBoxIcon"
                                  Header="MessageBox Icon"
                                  ItemsSource="{x:Bind MessageBoxIconItems, Mode=OneWay}"
                                  SelectedIndex="0" />
                        <ToggleSwitch x:Name="TGHasOwnerWindow"
                                      Header="Has Owner Window?"
                                      IsOn="True" />
                        <ToggleSwitch x:Name="TGHasTitleBar"
                                      Header="Has TitleBar?"
                                      IsOn="True" />
                        <ToggleSwitch x:Name="TGDragMove"
                                      Header="Drag by Content"
                                      IsOn="False" />
                        <ToggleSwitch x:Name="TGCanResize"
                                      Header="Can Resize?"
                                      IsOn="True" />
                        <ComboBox x:Name="CmbUnderlayBackdrops"
                                  Header="Backdrop"
                                  ItemsSource="{x:Bind BackdropItems, Mode=OneWay}"
                                  SelectedIndex="1" />
                    </StackPanel>
                </local:ControlExample.Pane>
                <StackPanel Spacing="10">
                    <Button Click="OnMessageBox"
                            Content="Show MessageBox"
                            Tag="None" />
                    <Button Click="OnMessageBox"
                            Content="Show Info MessageBox"
                            Tag="Info" />
                    <Button Click="OnMessageBox"
                            Content="Show Error MessageBox"
                            Tag="Error" />
                    <Button Click="OnMessageBox"
                            Content="Show Success MessageBox"
                            Tag="Success" />
                    <Button Click="OnMessageBox"
                            Content="Show Warning MessageBox"
                            Tag="Warning" />
                    <Button Click="OnMessageBox"
                            Content="Show Question MessageBox"
                            Tag="Question" />
                    <TextBlock x:Name="TxtResult"
                               Style="{ThemeResource TitleTextBlockStyle}" />
                </StackPanel>
            </local:ControlExample>
        </StackPanel>
    </ScrollViewer>

</Page>
