<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:DevWinUI"
                    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Style BasedOn="{StaticResource DefaultBetterLyricStyle}" TargetType="local:BetterLyric" />

    <Style x:Key="DefaultBetterLyricStyle" TargetType="local:BetterLyric">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:BetterLyric">
                    <Grid>
                        <win2d:CanvasAnimatedControl x:Name="PART_Canvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        <ScrollViewer x:Name="PART_ScrollViewer" VerticalScrollBarVisibility="Hidden">
                            <Grid />
                        </ScrollViewer>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
