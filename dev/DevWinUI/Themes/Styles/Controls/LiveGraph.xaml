<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:DevWinUI"
                    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Style BasedOn="{StaticResource DefaultLiveGraphStyle}" TargetType="local:LiveGraph" />

    <Style x:Key="DefaultLiveGraphStyle" TargetType="local:LiveGraph">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:LiveGraph">
                    <Grid>
                        <win2d:CanvasAnimatedControl x:Name="PART_Canvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClearColor="Transparent" />
                        <Grid x:Name="PART_HostGrid" Visibility="{TemplateBinding HighlightLineVisibility}">
                            <ContentPresenter Content="{TemplateBinding HighlightLineContent}" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
