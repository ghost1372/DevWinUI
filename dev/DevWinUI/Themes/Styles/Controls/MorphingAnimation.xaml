<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:DevWinUI"
                    xmlns:win2d="using:Microsoft.Graphics.Canvas.UI.Xaml">

    <Style BasedOn="{StaticResource DefaultMorphingAnimationStyle}" TargetType="local:MorphingAnimation" />

    <Style x:Key="DefaultMorphingAnimationStyle" TargetType="local:MorphingAnimation">
        <Setter Property="PrimaryColor" Value="{ThemeResource SystemAccentColor}" />
        <Setter Property="SecondaryColor" Value="{ThemeResource SystemAccentColorDark1}" />
        <Setter Property="MinHeight" Value="150" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:MorphingAnimation">
                    <win2d:CanvasAnimatedControl x:Name="PART_Canvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClearColor="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
