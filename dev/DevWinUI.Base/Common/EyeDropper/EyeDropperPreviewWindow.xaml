<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="DevWinUI.EyeDropperPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:DevWinUI"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.SystemBackdrop>
        <local:TransparentBackdrop />
    </Window.SystemBackdrop>

    <Grid Width="140" Height="40" Margin="5,0,0,0" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{StaticResource OverlayCornerRadius}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Border x:Name="PreviewBox" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource ControlCornerRadius}" />

        <TextBlock x:Name="TxtHex" Grid.Column="1" Margin="5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{ThemeResource BaseTextBlockStyle}" Text="#FFFFFFFF" />
    </Grid>

</Window>

